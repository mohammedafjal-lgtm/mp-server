# Copy to .env and fill in. Never commit .env.
# JWT secrets must be 32+ characters and randomly generated (e.g. openssl rand -base64 32).
# DATABASE_URL should match POSTGRES_* when using local Docker.

# Docker (used by docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-secure-password
POSTGRES_DB=marketplace
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin-password

# App
NODE_ENV=development
PORT=8000
DATABASE_URL=postgresql://postgres:change-me-secure-password@localhost:5432/marketplace
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-strong-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=another-strong-refresh-secret-min-32-chars
REDIS_CACHE_TTL=300
RATE_LIMIT_WRITE=10
